// ✅ Put your Google Sheet ID here (the long string in the sheet URL)
const SHEET_ID = "1fMB2ZEP1qLwFI4xxlQfuQO08MlpMt-gDL3NEyclWXsw";
const SHEET_NAME = "Sheet1";

function setupSheet_() {
  const ss = SpreadsheetApp.openById(SHEET_ID);
  const sh = ss.getSheetByName(SHEET_NAME) || ss.insertSheet(SHEET_NAME);

  if (sh.getLastRow() === 0) {
    sh.appendRow(["Timestamp", "Fruit", "Stage", "DaysRemaining", "Symptoms"]);
  }
  return sh;
}

// Web App endpoint: GET request
function doGet(e) {
  try {
    const sh = setupSheet_();

    const fruit = (e.parameter.fruit || "").toString();
    const stage = (e.parameter.stage || "").toString();
    const daysRemaining = (e.parameter.daysRemaining || "").toString();
    const symptoms = (e.parameter.symptoms || "").toString();

    const ts = new Date(); // server timestamp
    sh.appendRow([ts, fruit, stage, daysRemaining, symptoms]);

    return ContentService
      .createTextOutput(JSON.stringify({ ok: true }))
      .setMimeType(ContentService.MimeType.JSON);

  } catch (err) {
    return ContentService
      .createTextOutput(JSON.stringify({ ok: false, error: err.toString() }))
      .setMimeType(ContentService.MimeType.JSON);
  }
}



