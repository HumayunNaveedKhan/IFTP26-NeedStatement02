function handleRequest(e) {
  try {
    const ss = SpreadsheetApp.openById(SHEET_ID);
    const sheet = ss.getSheetByName(SHEET_NAME) || ss.getSheets()[0];

    // Create headers if empty
    if (sheet.getLastRow() === 0) {
      sheet.appendRow([
        "Timestamp",
        "Device",
        "MQ2 Raw",
        "MQ3 Raw",
        "MQ2 Diff",
        "MQ3 Diff",
        "Status",
        "Detected Gases",
        "RSSI",
        "Source IP / Note"
      ]);
    }

    const p = e.parameter || {};

    // Server-side timestamp (Pakistan time)
    const timestamp = Utilities.formatDate(new Date(), "Asia/Karachi", "yyyy-MM-dd HH:mm:ss");

    const row = [
      timestamp,
      p.device || "Unknown",
      toNumberOrKeep(p.mq2),
      toNumberOrKeep(p.mq3),
      toNumberOrKeep(p.mq2_diff),
      toNumberOrKeep(p.mq3_diff),
      p.status || "",
      p.gases || "",
      toNumberOrKeep(p.rssi),
      (p.note || "")
    ];

    sheet.appendRow(row);

    return ContentService
      .createTextOutput(JSON.stringify({
        success: true,
        message: "Row added",
        timestamp: timestamp
      }))
      .setMimeType(ContentService.MimeType.JSON);

  } catch (err) {
    return ContentService
      .createTextOutput(JSON.stringify({
        success: false,
        error: err.toString()
      }))
      .setMimeType(ContentService.MimeType.JSON);
  }
}

function toNumberOrKeep(v) {
  if (v === undefined || v === null || v === "") return "";
  const n = Number(v);
  return isNaN(n) ? v : n;
}
